{
  "name": "@uwckit/code-angular",
  "version": "1.0.0",
  "description": "UWCKit Angular component wrappers",
  "keywords": [
    "angular",
    "components",
    "uwckit"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@angular/common": "^17.x",
    "@angular/core": "^17.x",
    "@nitedani/vite-plugin-angular": "^17.0.11",
    "@uwckit/code-core": "*"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^1.9.0",
    "@angular-devkit/build-angular": "^17.3.0",
    "@angular/forms": "^17.3.0",
    "@angular/compiler": "^17.3.0",
    "@angular/compiler-cli": "^17.3.0",
    "@angular/platform-browser": "^17.3.0",
    "@angular/platform-browser-dynamic": "^17.3.0",
    "@types/node": "^20.12.12",
    "rxjs": "^7.8.1",
    "typescript": "^5.4.5",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^3.9.1",
    "zone.js": "^0.14.5",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "@angular/common": "^17.x",
    "@angular/core": "^17.x",
    "rxjs": "^7.x",
    "zone.js": "^0.14.x"
  },
  "publishConfig": {
    "access": "public"
  }
}