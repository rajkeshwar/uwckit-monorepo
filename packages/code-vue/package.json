{
  "name": "@uwckit/code-vue",
  "version": "1.0.0",
  "description": "UWCKit Vue 3 component wrappers",
  "keywords": ["vue", "vue3", "components", "uwckit"],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint src --ext .ts,.vue",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@uwckit/code-core": "*",
    "vue": "^3.4.27"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@vitejs/plugin-vue": "^5.0.4",
    "vite": "^5.2.11",
    "vite-plugin-dts": "^3.9.1",
    "vitest": "^1.6.0",
    "vue-tsc": "1.8.27"
  },
  "peerDependencies": {
    "vue": "^3.x"
  },
  "publishConfig": {
    "access": "public"
  }
}
